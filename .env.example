DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SITE_URL=http://127.0.0.1:8000
GOOGLE_SITE_VERIFICATION=
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password
# Optional if you later move from SQLite to Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/database
# Optional for explicit production hosts:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com
